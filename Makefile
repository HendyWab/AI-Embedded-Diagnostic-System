#==============================================================
#
#  Intelligent Embedded Diagnostic System (IEDS)
#  Makefile
#
#==============================================================

#==============================================================
#                      CONFIGURATION
#==============================================================

BUILD_DIR = build

#==============================================================
#                      DEFAULT TARGET
#==============================================================

all:
	@mkdir -p $(BUILD_DIR)
	cd $(BUILD_DIR) && cmake ..
	cd $(BUILD_DIR) && make

#==============================================================
#                      CLEAN TARGET
#==============================================================

clean:
	rm -rf $(BUILD_DIR)

#==============================================================
#                      REBUILD TARGET
#==============================================================

rebuild: clean all

#==============================================================
#                      RUN TARGET
#==============================================================

run:
	./$(BUILD_DIR)/ieds_firmware

#==============================================================
#                      HELP TARGET
#==============================================================

help:
	@echo "IEDS Build System"
	@echo ""
	@echo "Available targets:"
	@echo "  make        -> Build firmware"
	@echo "  make clean  -> Remove build files"
	@echo "  make rebuild-> Clean and rebuild"
	@echo "  make run    -> Run executable"
